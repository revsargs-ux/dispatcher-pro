// Check TG status after login
const _origShowMain=showMain;if(typeof showMain==='function'){const _s=showMain;showMain=function(){_s();checkTelegramStatus();checkMaxStatus();initGpsTracking();};}

// Push notifications + alarm
let alarmInterval=null,notifiedShifts=new Set();
function requestNotifications(){
  if('Notification' in window && Notification.permission==='default'){
    Notification.requestPermission();
  }
}
function sendPush(title,body){
  if('Notification' in window && Notification.permission==='granted'){
    new Notification(title,{body,icon:'/manifest.json',badge:'/manifest.json'});
  }
}
function startAlarmChecker(){if(alarmInterval)return;requestNotifications();alarmInterval=setInterval(checkAlarm,30000);checkAlarm();}
function checkAlarm(){
  if(!worker)return;const now=new Date();
  document.querySelectorAll('.card').forEach(card=>{
    const startMatch=card.textContent.match(/Начало:\\s*(\\d{2}:\\d{2})/);if(!startMatch)return;
    const dateMatch=card.querySelector('.date')?.textContent?.match(/(\\d{2}\\.\\d{2}\\.\\d{4})/);if(!dateMatch)return;
    const[_,dd,mm,yyyy]=dateMatch[0].match(/(\\d{2})\\.(\\d{2})\\.(\\d{4})/);
    const planned=new Date(yyyy+'-'+mm+'-'+dd+'T'+startMatch[1]+':00');
    const diff=(planned-now)/60000;
    const hasBtn=card.querySelector('.btn-work:not([disabled])');
    const key=planned.getTime();
    // 1 hour before
    if(diff<=60&&diff>55&&hasBtn&&!notifiedShifts.has('h1_'+key)){
      notifiedShifts.add('h1_'+key);sendPush('⏰ Через 1 час','Смена начинается в '+startMatch[1]);playAlarm();
    }
    // 15 min before
    if(diff<=15&&diff>10&&hasBtn&&!notifiedShifts.has('m15_'+key)){
      notifiedShifts.add('m15_'+key);sendPush('🚨 Через 15 минут!','Смена начинается в '+startMatch[1]);playAlarm();showAlarmNotice(planned);
    }
  });
}
function playAlarm(){
  try{const ctx=new(window.AudioContext||window.webkitAudioContext)();
  function beep(f,s,d){const o=ctx.createOscillator(),g=ctx.createGain();o.connect(g);g.connect(ctx.destination);o.frequency.value=f;o.type='sine';g.gain.value=0.3;o.start(ctx.currentTime+s);o.stop(ctx.currentTime+s+d);}
  for(let i=0;i<5;i++){beep(800,i*0.5,0.3);beep(1000,i*0.5+0.15,0.15);}
  }catch(e){}
}
function showAlarmNotice(planned){
  const o=document.createElement('div');
  o.style.cssText='position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.7);z-index:9999;display:flex;align-items:center;justify-content:center;';
  o.innerHTML='<div style="background:#fff;border-radius:16px;padding:30px;text-align:center;max-width:300px;"><div style="font-size:64px;">⏰</div><div style="font-size:20px;font-weight:bold;margin:12px 0;">Смена начинается!</div><div style="color:#666;">'+planned.toLocaleTimeString('ru',{hour:'2-digit',minute:'2-digit'})+'</div><button onclick="this.parentElement.parentElement.remove()" style="margin-top:16px;padding:12px 32px;background:var(--primary);color:#fff;border:none;border-radius:8px;font-size:16px;font-weight:bold;cursor:pointer;">Понятно</button></div>';
  document.body.appendChild(o);
}

// ============================================================
// GPS TRACKING
// ============================================================
let gpsActive = false;
let gpsSessionId = null;
let gpsLastUpdate = null;
let gpsBattery = null;
let gpsWorkerId = null;
let gpsPermissionGranted = false;
let swReady = null;

function getSwRegistration() {
  if (!swReady) swReady = navigator.serviceWorker?.ready;
  return swReady;
}

async function swMessage(msg) {
  const reg = await getSwRegistration();
  if (!reg || !reg.active) return null;
  return new Promise((resolve) => {
    const mc = new MessageChannel();
    mc.port1.onmessage = (e) => resolve(e.data);
    reg.active.postMessage(msg, [mc.port2]);
    setTimeout(() => resolve(null), 3000);
  });
}

function updateGpsBanner(state, details) {
  const banner = document.getElementById('gps-banner');
  const dot = document.getElementById('gps-dot');
  const statusText = document.getElementById('gps-status-text');
  const detailsEl = document.getElementById('gps-details');
  const toggle = document.getElementById('gps-toggle-input');

  banner.style.display = 'flex';
  banner.className = 'gps-banner';
  dot.className = 'gps-dot';

  if (state === 'active') {
    statusText.textContent = '📡 GPS трекинг активен';
    dot.className = 'gps-dot';
    gpsActive = true;
  } else if (state === 'inactive') {
    statusText.textContent = '📡 GPS трекинг выключен';
    banner.classList.add('inactive');
    dot.classList.add('off');
    gpsActive = false;
  } else if (state === 'error') {
    statusText.textContent = '📡 GPS: ошибка';
    banner.classList.add('error');
    dot.classList.add('err');
    gpsActive = false;
  } else if (state === 'waiting') {
    statusText.textContent = '📡 GPS: ожидание разрешения...';
    banner.classList.add('inactive');
    dot.classList.add('off');
  }

  if (details) detailsEl.textContent = details;
  else if (gpsLastUpdate) {
    const ago = Math.round((Date.now() - new Date(gpsLastUpdate).getTime()) / 60000);
    detailsEl.textContent = 'Обновлено ' + ago + ' мин назад' + (gpsBattery !== null ? ' · 🔋 ' + Math.round(gpsBattery * 100) + '%' : '');
  } else {
    detailsEl.textContent = '';
  }

  if (toggle) toggle.checked = gpsActive;

  // Battery warning
  if (gpsBattery !== null && gpsBattery < 0.15 && gpsActive) {
    detailsEl.textContent += ' ⚠️ Низкий заряд!';
  }
}

function showGpsPermissionModal() {
  return new Promise((resolve) => {
    const overlay = document.createElement('div');
    overlay.className = 'gps-modal-overlay';
    overlay.innerHTML = `<div class="gps-modal">
      <div style="font-size:48px">📍</div>
      <h3>Доступ к геолокации</h3>
      <p>Диспетчер запрашивает доступ к вашей геолокации для отслеживания на карте. Это помогает координировать работу. Вы можете отключить в любой момент.</p>
      <div class="btn-row">
        <button class="btn-deny" onclick="this.closest('.gps-modal-overlay').dataset.result='deny';this.closest('.gps-modal-overlay').remove()">Отклонить</button>
        <button class="btn-allow" onclick="this.closest('.gps-modal-overlay').dataset.result='allow';this.closest('.gps-modal-overlay').remove()">Разрешить</button>
      </div>
    </div>`;
    document.body.appendChild(overlay);
    const check = setInterval(() => {
      if (!document.body.contains(overlay)) { clearInterval(check); resolve(false); }
      else if (overlay.dataset.result) {
        clearInterval(check);
        const ok = overlay.dataset.result === 'allow';
        overlay.remove();
        resolve(ok);
      }
    }, 200);
  });
}

async function initGpsTracking() {
  if (!worker?.id) return;
  gpsWorkerId = worker.id;

  // Check if tracking is active on server
  try {
    const status = await api('tracking/status', 'GET', null, '?worker_id=' + worker.id);
    if (status?.active) {
      gpsSessionId = status.session_id;
      // Check SW tracking status
      const swStatus = await swMessage({ type: 'TRACKING_CHECK' });
      if (!swStatus?.active) {
        // Start in SW
        const token = localStorage.getItem('dp_token');
        await swMessage({
          type: 'START_TRACKING',
          session_id: gpsSessionId,
          worker_id: worker.id,
          token: token
        });
      }
      gpsActive = true;
      if (status.last_location) {
        gpsLastUpdate = status.last_location.created_at;
        gpsBattery = status.last_location.battery_level;
      }
      updateGpsBanner('active');
    } else {
      updateGpsBanner('inactive');
    }
  } catch (e) {
    console.warn('[GPS] Init error:', e);
    updateGpsBanner('inactive');
  }
}

async function toggleGpsTracking(enable) {
  const toggle = document.getElementById('gps-toggle-input');
  if (!worker?.id) return;

  if (enable) {
    // Check geolocation permission
    if (!gpsPermissionGranted) {
      const permResult = await navigator.permissions?.query({ name: 'geolocation' }).catch(() => null);
      if (permResult?.state === 'prompt') {
        const allowed = await showGpsPermissionModal();
        if (!allowed) { toggle.checked = false; return; }
      }
    }

    updateGpsBanner('waiting');

    // Request actual position to trigger permission
    try {
      await new Promise((resolve, reject) => {
        navigator.geolocation.getCurrentPosition(resolve, reject, {
          enableHighAccuracy: true, timeout: 15000, maximumAge: 60000
        });
      });
      gpsPermissionGranted = true;
    } catch (geoErr) {
      if (geoErr.code === 1) { // PERMISSION_DENIED
        updateGpsBanner('error', 'Доступ к геолокации запрещён');
        toggle.checked = false;
        toast('📍 Разрешите доступ к геолокации в настройках браузера');
        return;
      }
      // Other errors — still try to start
    }

    // Check if there's an active session
    try {
      const status = await api('tracking/status', 'GET', null, '?worker_id=' + worker.id);
      if (status?.active) {
        gpsSessionId = status.session_id;
      } else {
        // No active session — just enable local tracking mode
        updateGpsBanner('inactive');
        toggle.checked = false;
        toast('Нет активной сессии трекинга');
        return;
      }
    } catch {
      updateGpsBanner('inactive');
      toggle.checked = false;
      return;
    }

    // Start in SW
    const token = localStorage.getItem('dp_token');
    await swMessage({
      type: 'START_TRACKING',
      session_id: gpsSessionId,
      worker_id: worker.id,
      token: token
    });
    gpsActive = true;
    updateGpsBanner('active');
    toast('📡 GPS трекинг включён');
  } else {
    // Stop tracking
    await swMessage({ type: 'STOP_TRACKING' });
    gpsActive = false;
    gpsSessionId = null;
    updateGpsBanner('inactive');
    toast('📡 GPS трекинг выключен');
  }
}

// Listen for SW messages (tracking updates)
if ('serviceWorker' in navigator) {
  navigator.serviceWorker.addEventListener('message', (event) => {
    const msg = event.data;
    if (msg.type === 'TRACKING_UPDATE') {
      gpsLastUpdate = msg.location.timestamp;
      gpsBattery = msg.battery;
      updateGpsBanner('active');
    }
    if (msg.type === 'TRACKING_ERROR') {
      updateGpsBanner('error', msg.error);
    }
    if (msg.type === 'GET_AUTH_TOKEN') {
      const token = localStorage.getItem('dp_token');
      if (navigator.serviceWorker.controller) {
        navigator.serviceWorker.controller.postMessage({ type: 'AUTH_TOKEN_UPDATE', token: token });
      }
    }
  });
}

// Keep SW updated with fresh token
setInterval(() => {
  if (!gpsActive) return;
  const token = localStorage.getItem('dp_token');
  if (navigator.serviceWorker?.controller) {
    navigator.serviceWorker.controller.postMessage({ type: 'AUTH_TOKEN_UPDATE', token: token });
  }
}, 5 * 60 * 1000);

// Update GPS banner time display
setInterval(() => {
  if (gpsActive) updateGpsBanner('active');
}, 60000);

(async()=>{
  const p=new URLSearchParams(location.search);
  if(p.get('invite')==='1'||p.get('reg')==='1'){showReg();}
  const ok=await autoLogin();
})();
if('serviceWorker' in navigator){navigator.serviceWorker.register('/sw.js').then(function(r){console.log('[SW] registered',r.scope);}).catch(function(e){console.warn('[SW] error',e);});}
document.addEventListener('keydown',e=>{if(e.key==='Escape'){const m=document.querySelector('.modal[style*="flex"]')||document.querySelector('.modal[style*="block"]');if(m){m.style.display='none';}}});
initPhoneMasks();

// --- Shift photo upload ---
// --- Chat ---
let _chatShiftId=null,_chatPoll=null,_chatMyId=null;
function openChat(shiftId){
  _chatShiftId=shiftId;_chatMyId=worker?.id;
  document.getElementById('chat-modal').style.display='flex';
  loadChatMessages();
  _chatPoll=setInterval(loadChatMessages,5000);
}
function closeChat(){
  document.getElementById('chat-modal').style.display='none';
  if(_chatPoll)clearInterval(_chatPoll);_chatPoll=null;_chatShiftId=null;
}
async function loadChatMessages(){
  if(!_chatShiftId)return;
  try{
    const r=await fetch('/api/chat/'+_chatShiftId,{headers:{'Authorization':'Bearer '+localStorage.getItem('dp_token')}});
    const msgs=await r.json();
    if(!Array.isArray(msgs))return;
    const box=document.getElementById('chat-messages');
    const wasBottom=box.scrollTop+box.clientHeight>=box.scrollHeight-50;
    if(!msgs.length){box.innerHTML='<div class="chat-empty">Сообщений пока нет</div>';return;}
    box.innerHTML=msgs.map(m=>{
      const mine=m.sender_id===_chatMyId;
      const t=m.created_at?new Date(m.created_at).toLocaleTimeString('ru',{hour:'2-digit',minute:'2-digit'}):'';
      return `<div class="chat-msg ${mine?'me':'other'}"><div class="chat-sender">${mine?'Вы':esc(m.sender_name||'')}</div>${esc(m.message)}<div class="chat-time">${t}</div></div>`;
    }).join('');
    if(wasBottom)box.scrollTop=box.scrollHeight;
  }catch(e){console.error('chat load',e);}
}
async function sendChatMsg(){
  if(!_chatShiftId)return;
  const inp=document.getElementById('chat-input');
  const msg=inp.value.trim();if(!msg)return;
  inp.value='';
  try{
    await fetch('/api/chat/'+_chatShiftId,{method:'POST',headers:{'Content-Type':'application/json','Authorization':'Bearer '+localStorage.getItem('dp_token')},body:JSON.stringify({message:msg})});
    loadChatMessages();
  }catch(e){toast('Ошибка отправки');}
}
function esc(s){const d=document.createElement('div');d.textContent=s;return d.innerHTML;}

// --- Shift photo upload ---
let _photoInput=null;
function pickShiftPhoto(shiftId,asgnId){
  if(!_photoInput){_photoInput=document.createElement('input');_photoInput.type='file';_photoInput.accept='image/*';_photoInput.style.display='none';document.body.appendChild(_photoInput);}
  _photoInput.onchange=()=>uploadShiftPhoto(shiftId,_photoInput);
  _photoInput.click();
}
async function uploadShiftPhoto(shiftId,input){
  const file=input.files[0];if(!file)return;
  if(file.size>5*1024*1024){toast('Фото слишком большое (макс 5МБ)');return;}
  toast('📸 Загрузка фото...');
  try{
    const reader=new FileReader();
    const b64=await new Promise((res,rej)=>{reader.onload=()=>res(reader.result.split(',')[1]);reader.onerror=rej;reader.readAsDataURL(file);});
    const r=await fetch('/api/upload-shift-photo',{method:'POST',headers:{'Content-Type':'application/json','Authorization':'Bearer '+localStorage.getItem('dp_token')},body:JSON.stringify({filename:file.name,data:b64,shift_id:shiftId})});
    if(!r.ok){toast('Ошибка загрузки фото');return;}
    const d=await r.json();
    toast('✅ Фото добавлено');
    render();
  }catch(e){toast('Ошибка: '+e.message);}
  input.value='';
}
</script>
