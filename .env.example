# Dispatcher.PRO Environment Variables
# Copy this file to .env and fill in real values

# Supabase
SB_URL=https://your-project.supabase.co
SB_KEY=your_supabase_anon_key

# Telegram Bot
TG_BOT_TOKEN=your_telegram_bot_token

# MAX Bot
MAX_BOT_TOKEN=your_max_bot_token

# Google Apps Script
GAS_URL=your_gas_webhook_url
GAS_WEBHOOK_SECRET=your_gas_webhook_secret

# Gemini API
GEMINI_API_KEY=your_gemini_api_key

# Dadata (address suggestions)
DADATA_API_KEY=your_dadata_api_key
